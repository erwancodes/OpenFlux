---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ajouter un flux RSS" description="Ajoutez un flux RSS directement depuis l'interface." noindex>
  <div class="max-w-2xl mx-auto fade-in-up">

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-white mb-2">Ajouter un flux RSS</h1>
      <p class="text-sm text-zinc-400">Ajoutez un flux directement dans <code class="text-xs bg-zinc-800 px-1.5 py-0.5 rounded">feeds.yaml</code> via l'API GitHub.</p>
    </div>

    <!-- ============ Section 1: Token GitHub ============ -->
    <section class="af-section" id="token-section">
      <h2 class="af-section-title">
        <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
        Token GitHub
      </h2>

      <!-- Saved state -->
      <div id="token-saved" class="hidden af-key-bar">
        <div class="flex items-center gap-2">
          <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-[11px] text-zinc-400">Token</span>
          <span class="text-[11px] text-zinc-600 font-mono" id="token-preview"></span>
        </div>
        <button id="change-token" class="text-[11px] text-zinc-700 hover:text-zinc-400 transition-colors cursor-pointer">modifier</button>
      </div>

      <!-- Form state -->
      <div id="token-form">
        <div class="flex gap-1.5">
          <input
            type="password"
            id="token-input"
            placeholder="ghp_xxxxxxxxxxxx..."
            class="flex-1 px-2.5 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-700 focus:outline-none focus:border-indigo-500/50 text-xs font-mono transition-colors"
          />
          <button id="save-token" class="af-btn-primary text-xs px-3 py-1.5">OK</button>
        </div>
        <p class="mt-1.5 text-[11px] text-zinc-600">
          <a href="https://github.com/settings/tokens/new?scopes=public_repo&description=OpenFlux" target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:text-indigo-300 transition-colors">
            Creer un token
          </a> avec le scope <code class="text-[10px] bg-zinc-800 px-1 py-0.5 rounded">public_repo</code>
        </p>
      </div>
      <p id="token-status" class="mt-1 text-[11px] hidden"></p>
    </section>

    <!-- ============ Section 2: Formulaire ============ -->
    <section class="af-section" id="form-section">
      <h2 class="af-section-title">
        <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/></svg>
        Informations du flux
      </h2>

      <!-- URL + Test -->
      <div class="mb-4">
        <label class="af-label" for="feed-url">URL du flux RSS</label>
        <div class="flex gap-1.5">
          <input
            type="url"
            id="feed-url"
            placeholder="https://example.com/feed.xml"
            class="flex-1 px-2.5 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-700 focus:outline-none focus:border-indigo-500/50 text-xs font-mono transition-colors"
          />
          <button id="test-feed" class="af-btn-ghost text-xs px-3 py-1.5 flex items-center gap-1.5">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
            Tester
          </button>
        </div>
      </div>

      <!-- Test result -->
      <div id="test-result" class="hidden mb-4 p-3 rounded-lg border">
        <div id="test-success" class="hidden">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-xs font-medium text-emerald-400">Flux valide</span>
          </div>
          <p class="text-xs text-zinc-300 font-medium" id="test-title"></p>
          <p class="text-[11px] text-zinc-500 mt-1"><span id="test-count"></span> articles &middot; Dernier : <span id="test-latest"></span></p>
        </div>
        <div id="test-error" class="hidden">
          <div class="flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
            <span class="text-xs text-red-400" id="test-error-msg"></span>
          </div>
        </div>
      </div>

      <!-- Spinner during test -->
      <div id="test-loading" class="hidden mb-4 flex items-center gap-2 text-xs text-zinc-500">
        <svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
        Test du flux en cours...
      </div>

      <!-- Name -->
      <div class="mb-4">
        <label class="af-label" for="feed-name">Nom du flux</label>
        <input
          type="text"
          id="feed-name"
          placeholder="Ex: Mon Blog Tech"
          class="w-full px-2.5 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-700 focus:outline-none focus:border-indigo-500/50 text-xs transition-colors"
        />
      </div>

      <!-- Type -->
      <div class="mb-4">
        <span class="af-label">Type</span>
        <div class="flex gap-4 mt-1">
          <label class="af-radio">
            <input type="radio" name="feed-type" value="blog" checked class="sr-only peer" />
            <div class="af-radio-dot"></div>
            <span class="text-xs text-zinc-300">Blog</span>
          </label>
          <label class="af-radio">
            <input type="radio" name="feed-type" value="podcast" class="sr-only peer" />
            <div class="af-radio-dot"></div>
            <span class="text-xs text-zinc-300">Podcast</span>
          </label>
        </div>
      </div>

      <!-- Categories -->
      <div class="mb-2">
        <span class="af-label">Categories</span>
        <div class="flex flex-wrap gap-2 mt-1" id="categories-grid">
        </div>
      </div>
    </section>

    <!-- ============ Section 3: Soumission ============ -->
    <section class="af-section" id="submit-section">
      <button id="submit-feed" class="af-btn-submit w-full" disabled>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Ajouter le flux
      </button>

      <div id="submit-loading" class="hidden mt-3 flex items-center gap-2 text-xs text-zinc-500">
        <svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
        Commit en cours...
      </div>

      <div id="submit-result" class="hidden mt-3 p-3 rounded-lg border"></div>
    </section>

  </div>
</Layout>

<script>
  const GITHUB_OWNER = 'erwancodes';
  const GITHUB_REPO = 'OpenFlux';
  const GITHUB_FILE = 'feeds.yaml';
  const TOKEN_KEY = 'flux-github-token';
  const CORS_PROXY = 'https://api.allorigins.win/raw?url=';

  const PREDEFINED_CATEGORIES = [
    'Programmation', 'IA', 'DevOps', 'Cybersecurite',
    'Cloud', 'Web', 'Robotique', 'Vibe Coding',
  ];

  const $ = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  // --- Elements ---
  const tokenInput = $('#token-input');
  const saveTokenBtn = $('#save-token');
  const tokenSaved = $('#token-saved');
  const tokenForm = $('#token-form');
  const tokenPreview = $('#token-preview');
  const changeTokenBtn = $('#change-token');
  const tokenStatus = $('#token-status');

  const feedUrl = $('#feed-url');
  const testFeedBtn = $('#test-feed');
  const testResult = $('#test-result');
  const testSuccess = $('#test-success');
  const testError = $('#test-error');
  const testLoading = $('#test-loading');

  const feedName = $('#feed-name');
  const submitBtn = $('#submit-feed');
  const submitLoading = $('#submit-loading');
  const submitResult = $('#submit-result');

  // --- Render categories ---
  const categoriesGrid = $('#categories-grid');
  PREDEFINED_CATEGORIES.forEach((cat) => {
    const label = document.createElement('label');
    label.className = 'af-cat-label';
    label.innerHTML = `
      <input type="checkbox" name="category" value="${cat}" class="sr-only peer" />
      <div class="af-cat-chip">${cat === 'Cybersecurite' ? 'Cybers\u00e9curit\u00e9' : cat}</div>
    `;
    label.querySelector('input').addEventListener('change', validateForm);
    categoriesGrid.appendChild(label);
  });

  // --- Token management ---
  function maskToken(token) {
    return token.slice(0, 7) + '\u00b7\u00b7\u00b7\u00b7' + token.slice(-4);
  }

  function showSavedToken(token) {
    tokenForm.classList.add('hidden');
    tokenStatus.classList.add('hidden');
    tokenSaved.classList.remove('hidden');
    tokenPreview.textContent = maskToken(token);
  }

  function showTokenForm() {
    tokenSaved.classList.add('hidden');
    tokenForm.classList.remove('hidden');
    tokenInput.focus();
  }

  const savedToken = localStorage.getItem(TOKEN_KEY);
  if (savedToken) {
    tokenInput.value = savedToken;
    showSavedToken(savedToken);
  }

  saveTokenBtn.addEventListener('click', () => {
    const token = tokenInput.value.trim();
    if (token) {
      localStorage.setItem(TOKEN_KEY, token);
      showSavedToken(token);
    } else {
      tokenStatus.textContent = 'Token requis';
      tokenStatus.className = 'mt-1 text-[11px] text-red-400';
      tokenStatus.classList.remove('hidden');
    }
  });

  tokenInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') saveTokenBtn.click();
  });

  changeTokenBtn.addEventListener('click', showTokenForm);

  // --- Form validation ---
  function getToken() {
    return localStorage.getItem(TOKEN_KEY) || tokenInput.value.trim();
  }

  function getSelectedCategories() {
    return Array.from($$('input[name="category"]:checked')).map((cb) => cb.value);
  }

  function getSelectedType() {
    return document.querySelector('input[name="feed-type"]:checked')?.value || 'blog';
  }

  function validateForm() {
    const hasUrl = feedUrl.value.trim().length > 0;
    const hasName = feedName.value.trim().length > 0;
    const hasCats = getSelectedCategories().length > 0;
    const hasToken = !!getToken();
    submitBtn.disabled = !(hasUrl && hasName && hasCats && hasToken);
  }

  feedUrl.addEventListener('input', validateForm);
  feedName.addEventListener('input', validateForm);
  $$('input[name="feed-type"]').forEach((r) => r.addEventListener('change', validateForm));

  // --- Test RSS feed ---
  async function fetchFeedXml(url) {
    try {
      const resp = await fetch(url);
      if (resp.ok) return await resp.text();
    } catch {}

    const proxyUrl = CORS_PROXY + encodeURIComponent(url);
    const resp = await fetch(proxyUrl);
    if (!resp.ok) throw new Error("Impossible d'acceder au flux.");
    return resp.text();
  }

  function parseRssFeed(xmlText) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(xmlText, 'text/xml');

    const parseError = doc.querySelector('parsererror');
    if (parseError) throw new Error('Pas un flux RSS valide.');

    // RSS 2.0
    let title = doc.querySelector('channel > title')?.textContent;
    let items = doc.querySelectorAll('item');

    // Atom fallback
    if (!title) {
      title = doc.querySelector('feed > title')?.textContent;
      items = doc.querySelectorAll('entry');
    }

    if (!title && items.length === 0) throw new Error('Pas un flux RSS valide.');

    const latestTitle = items[0]?.querySelector('title')?.textContent || 'N/A';

    return { title: title || 'Sans titre', count: items.length, latest: latestTitle };
  }

  testFeedBtn.addEventListener('click', async () => {
    const url = feedUrl.value.trim();
    if (!url) return;

    testResult.classList.add('hidden');
    testSuccess.classList.add('hidden');
    testError.classList.add('hidden');
    testLoading.classList.remove('hidden');
    testFeedBtn.disabled = true;

    try {
      const xml = await fetchFeedXml(url);
      const info = parseRssFeed(xml);

      $('#test-title').textContent = info.title;
      $('#test-count').textContent = info.count;
      $('#test-latest').textContent = info.latest.length > 60 ? info.latest.slice(0, 60) + '...' : info.latest;

      testSuccess.classList.remove('hidden');
      testResult.classList.remove('hidden');
      testResult.className = 'mb-4 p-3 rounded-lg border border-emerald-500/20 bg-emerald-500/5';

      // Auto-fill name if empty
      if (!feedName.value.trim()) {
        feedName.value = info.title;
        validateForm();
      }
    } catch (err) {
      $('#test-error-msg').textContent = err.message;
      testError.classList.remove('hidden');
      testResult.classList.remove('hidden');
      testResult.className = 'mb-4 p-3 rounded-lg border border-red-500/20 bg-red-500/5';
    } finally {
      testLoading.classList.add('hidden');
      testFeedBtn.disabled = false;
    }
  });

  // --- YAML helpers ---
  function escapeYamlValue(value) {
    if (/[:#\[\]{}|>&*!?,]/.test(value) || value.startsWith("'") || value.startsWith('"')) {
      return `"${value.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
    }
    return value;
  }

  function buildYamlEntry(url, name, type, categories) {
    // Map display names back to YAML category names
    const catMap = { 'Cybers\u00e9curit\u00e9': 'Cybersecurite' };
    const yamlCats = categories.map((c) => catMap[c] || c);

    let entry = `\n  - url: ${url}\n    name: ${escapeYamlValue(name)}`;
    if (type === 'podcast') {
      entry += `\n    type: podcast`;
    }
    entry += `\n    categories: [${yamlCats.join(', ')}]`;
    return entry;
  }

  // --- GitHub API ---
  async function getFileFromGitHub(token) {
    const resp = await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${GITHUB_FILE}`, {
      headers: {
        Authorization: `Bearer ${token}`,
        Accept: 'application/vnd.github.v3+json',
      },
    });

    if (resp.status === 401) throw new Error('Token GitHub invalide ou expire.');
    if (resp.status === 403) throw new Error('Scope public_repo requis.');
    if (!resp.ok) throw new Error(`Erreur GitHub: ${resp.status}`);

    return resp.json();
  }

  async function updateFileOnGitHub(token, content, sha, commitMessage) {
    const resp = await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${GITHUB_FILE}`, {
      method: 'PUT',
      headers: {
        Authorization: `Bearer ${token}`,
        Accept: 'application/vnd.github.v3+json',
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        message: commitMessage,
        content: btoa(unescape(encodeURIComponent(content))),
        sha: sha,
      }),
    });

    if (resp.status === 409) throw new Error('Le fichier a ete modifie. Reessayez.');
    if (resp.status === 401) throw new Error('Token GitHub invalide ou expire.');
    if (resp.status === 403) throw new Error('Scope public_repo requis.');
    if (!resp.ok) throw new Error(`Erreur GitHub: ${resp.status}`);

    return resp.json();
  }

  // --- Submit ---
  submitBtn.addEventListener('click', async () => {
    const token = getToken();
    const url = feedUrl.value.trim();
    const name = feedName.value.trim();
    const type = getSelectedType();
    const categories = getSelectedCategories();

    if (!token || !url || !name || categories.length === 0) return;

    submitBtn.disabled = true;
    submitLoading.classList.remove('hidden');
    submitResult.classList.add('hidden');

    try {
      // 1. Get current file
      const file = await getFileFromGitHub(token);
      const currentContent = decodeURIComponent(escape(atob(file.content.replace(/\n/g, ''))));

      // 2. Check for duplicates
      if (currentContent.includes(url)) {
        throw new Error('Ce flux est deja present.');
      }

      // 3. Append new entry
      const newEntry = buildYamlEntry(url, name, type, categories);
      const updatedContent = currentContent.trimEnd() + '\n' + newEntry + '\n';

      // 4. Commit
      const result = await updateFileOnGitHub(
        token,
        updatedContent,
        file.sha,
        `\u2795 Ajout du flux : ${name}`
      );

      const commitUrl = result.commit?.html_url || `https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}`;

      submitResult.innerHTML = `
        <div class="flex items-center gap-2 mb-1">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="text-xs font-medium text-emerald-400">Flux ajoute avec succes !</span>
        </div>
        <p class="text-[11px] text-zinc-500">Le prochain cron (4h UTC) recuperera les articles. Vercel redeploiera automatiquement.</p>
        <a href="${commitUrl}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-2 text-[11px] text-indigo-400 hover:text-indigo-300 transition-colors">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          Voir le commit
        </a>
      `;
      submitResult.className = 'mt-3 p-3 rounded-lg border border-emerald-500/20 bg-emerald-500/5';
      submitResult.classList.remove('hidden');

      // Reset form
      feedUrl.value = '';
      feedName.value = '';
      $$('input[name="category"]:checked').forEach((cb) => { cb.checked = false; });
      document.querySelector('input[name="feed-type"][value="blog"]').checked = true;
      testResult.classList.add('hidden');
      // Re-render category chips
      $$('.af-cat-label').forEach((label) => {
        const chip = label.querySelector('.af-cat-chip');
        chip.classList.remove('af-cat-active');
      });

    } catch (err) {
      submitResult.innerHTML = `
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
          <span class="text-xs text-red-400">${escapeHtml(err.message)}</span>
        </div>
      `;
      submitResult.className = 'mt-3 p-3 rounded-lg border border-red-500/20 bg-red-500/5';
      submitResult.classList.remove('hidden');
    } finally {
      submitLoading.classList.add('hidden');
      validateForm();
    }
  });

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Initial validation
  validateForm();
</script>

<style is:global>
  /* ---- Sections ---- */
  .af-section {
    margin-bottom: 24px;
    padding: 20px;
    background: linear-gradient(145deg, rgba(24, 24, 27, 0.5), rgba(9, 9, 11, 0.7));
    border: 1px solid rgba(39, 39, 42, 0.5);
    border-radius: 14px;
  }

  .af-section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #e4e4e7;
    margin-bottom: 12px;
  }

  .af-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: #71717a;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ---- Key bar (same as rs.astro) ---- */
  .af-key-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 10px;
    border-radius: 8px;
    background: rgba(16, 185, 129, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.1);
  }

  /* ---- Buttons ---- */
  .af-btn-primary {
    background: #6366f1;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .af-btn-primary:hover { background: #818cf8; }

